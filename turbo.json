{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEON_POSTGRES_URL",
        "POSTGRES_URL",
        "DATABASE_URL",
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
        "NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL",
        "NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_STAFF_SKOOL_ID",
        "CRON_SECRET",
        "GHL_API_KEY",
        "GHL_LOCATION_ID",
        "GHL_PRIVATE_INTEGRATION_TOKEN",
        "GHL_MARKETPLACE_CLIENT_ID",
        "GHL_MARKETPLACE_CLIENT_SECRET",
        "GHL_MARKETPLACE_WEBHOOK_SECRET",
        "GHL_MARKETPLACE_REFRESH_TOKEN",
        "GHL_MARKETPLACE_ACCESS_TOKEN",
        "GHL_MARKETPLACE_TOKEN_EXPIRES",
        "GHL_CONVERSATION_PROVIDER_ID",
        "META_ACCESS_TOKEN",
        "META_AD_ACCOUNT_ID",
        "EXTERNAL_API_KEY",
        "EXTENSION_API_KEY",
        "TELEMETRY_API_KEY",
        "PLAID_CLIENT_ID",
        "PLAID_SECRET",
        "PLAID_ENV",
        "PLAID_ENCRYPTION_KEY",
        "COOKIE_ENCRYPTION_KEY",
        "WIDGET_API_KEY",
        "DOWNLOAD_TOKEN",
        "EARNINGS_PER_MEMBER"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
