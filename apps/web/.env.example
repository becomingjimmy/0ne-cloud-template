# ============================================
# 0ne Cloud Environment Variables
# ============================================

# --- Database (Neon PostgreSQL) ---
NEON_POSTGRES_URL=

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://app.0neos.com

# --- Cron Security ---
CRON_SECRET=

# --- GoHighLevel (KPI Dashboard - Legacy API Key) ---
GHL_API_KEY=
GHL_LOCATION_ID=

# --- GoHighLevel (Private Integration Token - Media Manager) ---
GHL_PRIVATE_INTEGRATION_TOKEN=

# --- GoHighLevel (Marketplace App - Skool DM Sync) ---
GHL_MARKETPLACE_CLIENT_ID=
GHL_MARKETPLACE_CLIENT_SECRET=
GHL_MARKETPLACE_WEBHOOK_SECRET=
GHL_MARKETPLACE_REFRESH_TOKEN=
GHL_MARKETPLACE_ACCESS_TOKEN=
GHL_MARKETPLACE_TOKEN_EXPIRES=
GHL_CONVERSATION_PROVIDER_ID=
GHL_ENCRYPTION_KEY=  # 64 hex chars (32 bytes) - generate with: openssl rand -hex 32

# --- Meta Ads (KPI Dashboard) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# --- Extension API (Chrome Extension auth) ---
EXTENSION_API_KEY=

# --- External API (Claude/One post creation) ---
EXTERNAL_API_KEY=

# --- Telemetry (Doctor + Install Wizard reports) ---
TELEMETRY_API_KEY=

# --- Plaid Banking Integration ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_ENCRYPTION_KEY=  # 64 hex chars (32 bytes) - generate with: openssl rand -hex 32

# --- Cookie Encryption (Skool cookie storage) ---
COOKIE_ENCRYPTION_KEY=  # 64 hex chars (32 bytes) - generate with: openssl rand -hex 32

# --- iOS Widget ---
WIDGET_API_KEY=

# --- Download Token (template zip) ---
DOWNLOAD_TOKEN=

# --- KPI Tuning ---
EARNINGS_PER_MEMBER=73.77

# --- Skool Sync UI ---
NEXT_PUBLIC_STAFF_SKOOL_ID=
